{
  "name": "the-new-wave-backend",
  "version": "1.0.0",
  "description": "Backend API for The New Wave - Youth Innovation Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watchAll --detectOpenHandles",
    "seed": "node scripts/seedDatabase.js",
    "migrate": "node scripts/migrate.js",
    "build": "npm install",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "keywords": [
    "innovation",
    "youth",
    "mentorship",
    "ai",
    "social-impact",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "The New Wave Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.8.1",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "axios": "^1.5.0",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.40.0",
    "nodemailer": "^6.9.4",
    "stripe": "^13.2.0",
    "socket.io": "^4.7.2",
    "redis": "^4.6.7",
    "agenda": "^4.3.0",
    "winston": "^3.10.0",
    "express-winston": "^4.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "eslint": "^8.47.0",
    "eslint-config-node": "^4.1.0",
    "mongodb-memory-server": "^8.15.1",
    "@faker-js/faker": "^8.0.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/the-new-wave/backend.git"
  },
  "bugs": {
    "url": "https://github.com/the-new-wave/backend/issues"
